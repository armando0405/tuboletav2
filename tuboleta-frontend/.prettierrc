{
    "singleQuote": true,
    "semi": false,
    "tabWidth": 4,
    "printWidth": 100,
    "trailingComma": "all",
    "bracketSpacing": true,
    "useTabs": false,
    "singleAttributePerLine": true,
    "htmlWhitespaceSensitivity": "ignore",
    "vueIndentScriptAndStyle": false,
    "endOfLine": "lf"
}
